# ============================================================
# Backend environment variables
# Copy this file to .env and fill in the values.
# Never commit .env to git.
# ============================================================

# Django
SECRET_KEY=change-me-generate-with-python-manage.py-shell
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=portfolio_db
DB_USER=portfolio_user
DB_PASSWORD=your_db_password_here
DB_HOST=localhost
DB_PORT=5432

# Settings module
DJANGO_SETTINGS_MODULE=portfolio.settings.development

# Wagtail
WAGTAIL_SITE_NAME=Rezwoan Portfolio

# CORS (comma-separated list of allowed frontend origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Media files (leave blank to use default: backend/media/)
MEDIA_ROOT=

# Email (optional — only needed in production)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@rezwoan.me
