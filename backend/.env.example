# Backend environment — copy to .env and fill in. NEVER commit the real .env.
# (The repo is public; real values live only on the Pi.)

NODE_ENV=development
PORT=3201
FRONTEND_URL=http://localhost:3200

# Prisma / SQLite (path is relative to backend/prisma at runtime)
DATABASE_URL="file:./portfolio.db"

# Auth
JWT_SECRET=dev-only-change-me
JWT_EXPIRY=7d
ADMIN_EMAIL=frezwoan@gmail.com
ADMIN_PASSWORD=admin12345

# Email (Resend) — https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=Rezwoan <noreply@rezwoan.me>
CONTACT_TO_EMAIL=frezwoan@gmail.com

# AI (Google Gemini) — https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# GitHub importer (optional token raises API rate limit 60 -> 5000/hr)
GITHUB_TOKEN=
