# dependencies
node_modules/
.pnp/
.pnp.js

# builds
.next/
out/
dist/
build/

# database (lives only on the Pi, never committed)
*.db
*.db-journal
*.sqlite
*.sqlite3
backend/prisma/*.db

# uploaded media (lives only on the Pi)
backend/uploads/*
!backend/uploads/.gitkeep

# env / secrets — NEVER commit
.env
.env.*
!.env.example
!.env.local.example

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# os / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# legacy python (old stack)
venv/
__pycache__/

# misc
*.tsbuildinfo
coverage/
.cache/
